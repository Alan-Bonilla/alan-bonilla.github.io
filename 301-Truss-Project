<div class="panel" style="grid-column: 1 / -1; display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
    
    <div style="display: flex; flex-direction: column;">
        <div class="sidebar-title" style="display: flex; justify-content: space-between;">
            <span>Structural Definition (JSON)</span>
            <div style="display: flex; gap: 0.5rem;">
                <button class="btn-secondary" style="padding: 2px 8px; font-size: 0.7rem;" onclick="formatJSON()">Auto-Format</button>
                <button class="btn-secondary" style="padding: 2px 8px; font-size: 0.7rem;" onclick="clearInput()">Clear</button>
            </div>
        </div>
        
        <div style="position: relative; flex: 1;">
            <div id="line-numbers" style="position: absolute; left: 0; top: 0; width: 30px; height: 100%; background: rgba(0,0,0,0.3); color: #475569; font-family: monospace; font-size: 0.85rem; padding: 1rem 5px; text-align: right; border-radius: 8px 0 0 8px; pointer-events: none; overflow: hidden;">
                1<br>2<br>3<br>4<br>5<br>6<br>7<br>8<br>9<br>10...
            </div>
            <textarea id="json-input" 
                style="width: 100%; height: 450px; padding-left: 40px; background: #020617; border: 1px solid var(--accent-blue); color: #60a5fa;" 
                spellcheck="false" 
                oninput="updateInspector()"></textarea>
        </div>
        
        <div class="btn-group" style="margin-top: 1rem;">
            <button class="btn-primary" onclick="runAnalysis()" style="height: 50px; font-size: 1.1rem;">⚡ EXECUTE ANALYSIS</button>
        </div>
    </div>

    <div style="display: flex; flex-direction: column; background: rgba(0,0,0,0.2); border-radius: 8px; padding: 1rem; border: 1px dashed var(--border-color);">
        <div class="sidebar-title">Live Data Inspector</div>
        
        <div id="inspector-content" style="overflow-y: auto; max-height: 480px;">
            <div style="color: var(--text-muted); text-align: center; margin-top: 4rem;">
                <p>Waiting for valid JSON input...</p>
                <p style="font-size: 0.8rem;">Paste your EK301 .mat proxy data to see the breakdown.</p>
            </div>
        </div>
    </div>
</div>

<script>
    // --- Logic for the Enhanced Section ---

    function updateInspector() {
        const target = document.getElementById('inspector-content');
        const raw = document.getElementById('json-input').value;

        try {
            const data = JSON.parse(raw);
            const J = data.X.length;
            const M = data.C[0].length;

            let html = `
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 1.5rem;">
                    <div class="metric-card" style="padding: 10px;">
                        <div class="metric-label">Joints (J)</div>
                        <div class="metric-value" style="font-size: 1.2rem; color: #f8fafc;">${J}</div>
                    </div>
                    <div class="metric-card" style="padding: 10px;">
                        <div class="metric-label">Members (M)</div>
                        <div class="metric-value" style="font-size: 1.2rem; color: #f8fafc;">${M}</div>
                    </div>
                </div>
                
                <h4 style="font-size: 0.8rem; color: var(--accent-blue); margin-bottom: 0.5rem;">COORDINATE MAP</h4>
                <table style="width:100%; font-size: 0.8rem; margin-bottom: 1.5rem;">
                    <tr style="color: var(--text-muted);"><th>ID</th><th>X (in)</th><th>Y (in)</th><th>Load (oz)</th></tr>
            `;

            for (let i = 0; i < J; i++) {
                const loadY = data.L[i + J] || 0;
                const loadStyle = loadY < 0 ? 'color: #ef4444; font-weight: bold;' : '';
                html += `
                    <tr>
                        <td>J${i+1}</td>
                        <td>${data.X[i]}</td>
                        <td>${data.Y[i]}</td>
                        <td style="${loadStyle}">${loadY !== 0 ? loadY + ' ↓' : '--'}</td>
                    </tr>
                `;
            }

            html += `</table><h4 style="font-size: 0.8rem; color: var(--accent-blue); margin-bottom: 0.5rem;">SUPPORT CONFIGURATION</h4>`;
            
            // Basic support detection from Sy matrix
            let supports = [];
            for(let j=0; j<J; j++) {
                if(data.Sy[j][1] === 1) supports.push(`J${j+1} (Pin)`);
                else if(data.Sy[j][2] === 1) supports.push(`J${j+1} (Roller)`);
            }
            
            html += `<p style="font-size: 0.85rem;">${supports.join(' & ') || 'No supports detected'}</p>`;
            
            target.innerHTML = html;
        } catch (e) {
            target.innerHTML = `<div style="color: #ef4444; font-size: 0.85rem; padding: 1rem; background: rgba(239, 68, 68, 0.1); border-radius: 4px;">
                <strong>Invalid JSON Format:</strong><br>${e.message}
            </div>`;
        }
    }

    function formatJSON() {
        const input = document.getElementById('json-input');
        try {
            const obj = JSON.parse(input.value);
            input.value = JSON.stringify(obj, null, 4);
            updateInspector();
        } catch (e) { alert("Cannot format: Invalid JSON"); }
    }

    function clearInput() {
        document.getElementById('json-input').value = "";
        updateInspector();
    }

    // Initialize with sample data if needed
    window.addEventListener('load', () => {
        // Assuming loadSampleData() from your previous script is available
        if (typeof loadSampleData === 'function') loadSampleData();
        updateInspector();
    });
</script>
